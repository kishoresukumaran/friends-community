# Copy this file to .env.local and fill in the values.

# MongoDB Atlas connection string (from Atlas > Cluster0 > Connect > Drivers).
# Make sure it includes the database name, e.g.
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/friends_community?retryWrites=true&w=majority
MONGODB_URI=

# Database name (used as a fallback / override if not in the URI).
MONGODB_DB=friends_community

# Password for the in-app admin area (/admin). Pick something only you know.
ADMIN_PASSWORD=change-me

# Random secret used to sign the admin session cookie. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Shared secret the FIFA 2026 Google Apps Script uses to authenticate its
# 5-minute sync to /api/fifa/sync. Use a long random string and set the same
# value in the Apps Script Script Properties (SYNC_SECRET).
FIFA_SYNC_SECRET=change-me-to-a-long-random-string
